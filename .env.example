# Bot Name (Default: HavanaAi)
BOT_NAME=HavanaAi

# Owner WhatsApp Number with country code (without + or spaces)
# Example: 923001234567
OWNER_NUMBER=

# Command Prefix (Default: .)
PREFIX=.

# Authentication Folder (Default: auth_info)
AUTH_FOLDER=auth_info

# Session ID (Optional - for reusing session)
SESSION_ID=

# Bot Mode (public/private) - Default: public
# PUBLIC_MODE=true
